{{- $pages := slice -}}
{{- range site.RegularPages -}}
  {{- $pages = $pages | append (dict "title" .Title "url" .RelPermalink "section" .Section "summary" ((.Description | default .Summary) | plainify) "tags" (.Params.tags | default (slice)) "date" (.Date.Format "2006-01-02")) -}}
{{- end -}}
{{- $pages | jsonify -}}
